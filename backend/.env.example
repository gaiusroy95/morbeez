# Server
NODE_ENV=development
PORT=3000
API_BASE_URL=https://api-staging.morbeez.in
LOG_LEVEL=info

# Supabase
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_ANON_KEY=eyJ...
# Optional ΓÇö for npm run db:reset-retest -- --confirm --sql (faster full reset via Postgres)
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Shopify
# Must match the store where your live theme runs (e.g. morbeez-india.myshopify.com)
SHOPIFY_STORE_DOMAIN=morbeez-india.myshopify.com
SHOPIFY_ADMIN_API_ACCESS_TOKEN=shpat_...
SHOPIFY_API_VERSION=2024-10
# Optional: Shopify location id for stock updates (Inventory Levels API)
# SHOPIFY_LOCATION_ID=
SHOPIFY_WEBHOOK_SECRET=whsec_...
# Partner app (install + app proxy HMAC) ΓÇö from dev.shopify.com ΓåÆ morbeez ΓåÆ Settings
SHOPIFY_APP_CLIENT_ID=87add483c25cbce127ee00731fb8e5a7
SHOPIFY_APP_CLIENT_SECRET=shpss_...
SHOPIFY_APP_SCOPES=write_app_proxy
# Partner app version URLs (must match):
#   App URL: https://YOUR_API/auth/shopify/installed
#   Allowed redirection URL: https://YOUR_API/auth/shopify/callback

# Outbox retry worker (polls failed events every 30s)
ENABLE_OUTBOX_WORKER=true

# Razorpay
RAZORPAY_KEY_ID=rzp_live_xxx
RAZORPAY_KEY_SECRET=xxx
RAZORPAY_WEBHOOK_SECRET=whsec_razorpay
# Storefront: Razorpay Orders API (cart ΓåÆ /pages/checkout, not Shopify checkout)
ENABLE_RAZORPAY_CHECKOUT=true
CHECKOUT_SUCCESS_PATH=/pages/checkout-success

# Shiprocket ΓÇö API credentials (Settings ΓåÆ API ΓåÆ Create API user; NOT main login)
SHIPROCKET_EMAIL=api-user@your-domain.com
SHIPROCKET_PASSWORD=api_user_password_here
# Must match pickup nickname in Shiprocket ΓåÆ Settings ΓåÆ Pickup addresses (e.g. Primary)
SHIPROCKET_PICKUP_LOCATION=Primary
SHIPROCKET_PICKUP_PINCODE=560001
# Webhook auth token (Shiprocket ΓåÆ Webhooks ΓåÆ x-api-key) ΓÇö separate from API password
# Webhook URL in Shiprocket dashboard:
#   https://YOUR_API_BASE_URL/webhooks/tracking
# Legacy alias also accepted: /api/v1/shiprocket/webhook
SHIPROCKET_WEBHOOK_TOKEN=your_long_random_secret_here

# WhatsApp ΓÇö provider: cloud (Meta) | adsgyani | wati | interakt
WHATSAPP_PROVIDER=cloud

# ΓöÇΓöÇΓöÇ Ads Gyani (adsgyani.in) ΓÇö WA Mantra API v1.0 ΓöÇΓöÇΓöÇ
# Settings ΓåÆ API & Webhook: Base URL, Vendor UID (UUID), API Access Token
# Docs: https://adsgyani.in/api-docs.pdf
ADS_GYANI_API_BASE=https://adsgyani.in/api
ADS_GYANI_TENANT=7f463da3-64ee-4926-949b-450605610908
ADS_GYANI_API_TOKEN=your_64_char_api_access_token
# Webhook: enable in dashboard ΓåÆ POST https://<API_BASE_URL>/webhooks/whatsapp/adsgyani
ADS_GYANI_WEBHOOK_VERIFY_TOKEN=morbeez_adsgyani_verify_change_me
ADS_GYANI_WEBHOOK_SECRET=
ADS_GYANI_SEND_TEXT_PATH=/contact/send-message
ADS_GYANI_SEND_TEMPLATE_PATH=/contact/send-template-message
ADS_GYANI_TEMPLATE_LANGUAGE=en
# Approved template names in Ads Gyani / Meta (required for first contact & outside 24h window)
WHATSAPP_WELCOME_TEMPLATE=
WHATSAPP_OUTBOUND_TEMPLATE=
# Login OTP ΓÇö one body variable = 6-digit code (required for real OTP on phone in production)
WHATSAPP_OTP_TEMPLATE=morbeez_otp_verification
# If template uses en_US in Meta/Ads Gyani, set explicitly (otherwise tries en then en_US)
# WHATSAPP_OTP_TEMPLATE_LANGUAGE=en_US
# Local/staging: set true to send real WhatsApp OTP instead of showing Dev OTP in the app
OTP_SEND_VIA_WHATSAPP=true
WHATSAPP_SESSION_HOURS=24
# Public storefront for product links in WhatsApp replies
SHOPIFY_STOREFRONT_URL=https://morbeez-india.myshopify.com

# ΓöÇΓöÇΓöÇ Meta WhatsApp Cloud API (WHATSAPP_PROVIDER=cloud) ΓöÇΓöÇΓöÇ
# Meta App ΓåÆ WhatsApp ΓåÆ Configuration:
#   Callback URL: https://YOUR_API/webhooks/whatsapp
#   Verify token: must match WHATSAPP_VERIFY_TOKEN exactly (copy both sides)
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_VERIFY_TOKEN=morbeez_whatsapp_verify_change_me
WHATSAPP_BUSINESS_ACCOUNT_ID=

# ΓöÇΓöÇΓöÇ WATI (if WHATSAPP_PROVIDER=wati) ΓöÇΓöÇΓöÇ
WATI_API_ENDPOINT=https://live-mt-server.wati.io
WATI_ACCESS_TOKEN=

# ΓöÇΓöÇΓöÇ Interakt (if WHATSAPP_PROVIDER=interakt) ΓöÇΓöÇΓöÇ
INTERAKT_API_KEY=

# OpenAI ΓÇö Crop Doctor (M3)
OPENAI_API_KEY=sk-...
OPENAI_VISION_MODEL=gpt-4o
# Crop Doctor JSON advisory ΓÇö use gpt-4o (or gpt-4.1). o1/o3 need max_completion_tokens (handled in code) but may not support json_object.
OPENAI_TEXT_MODEL=gpt-4o
OPENAI_WHISPER_MODEL=whisper-1

# Plant.id ΓÇö supplemental disease signal
PLANT_ID_API_KEY=

# Security
INTERNAL_API_KEY=generate_long_random_key_for_admin_routes
# Website farmer login JWT (min 32 chars ΓÇö openssl rand -hex 32)
FARMER_JWT_SECRET=5ccc4365fd9dfde4256a0e360a0b6d1a88fae796b10800336d11b475c31adb5d
# Staff admin portal (/admin) ΓÇö openssl rand -hex 32
ADMIN_JWT_SECRET=change_me_admin_jwt_secret_min_32_chars
# Staff console SPA (invite / reset links) ΓÇö Vercel or local Vite (no /morbeez-staff suffix)
CONSOLE_PUBLIC_URL=http://localhost:5173
# CORS: comma-separated origins for the staff console (required in production with separate frontend)
ADMIN_UI_ORIGIN=http://localhost:5173
# Production examples:
# CONSOLE_PUBLIC_URL=https://staff.morbeez.in
# ADMIN_UI_ORIGIN=https://staff.morbeez.in
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# Feature flags
# Fulfillment: create Shiprocket order + AWB when warehouse confirms (recommended).
ENABLE_SHIPROCKET_ON_CONFIRM=true
# Legacy: only create shipment after pack if AWB missing.
ENABLE_SHIPROCKET_AUTO_SHIP=false
ENABLE_SHIPROCKET_AFTER_PACK=false
ENABLE_OMS_AUTO_CONFIRM=true
COMPANY_GSTIN=
COMPANY_STATE=Karnataka
COMPANY_LEGAL_NAME=Morbeez Agri Sciences

# SEO Control Panel ΓÇö Google Search Console (optional)
GSC_SITE_URL=https://morbeez-india.myshopify.com
GSC_CLIENT_ID=
GSC_CLIENT_SECRET=
GSC_REFRESH_TOKEN=
\\
ENABLE_RAZORPAY_PAYMENT_LINKS=true
ENABLE_WHATSAPP_AUTO_REPLY=false
# OpenAI auto-replies on WhatsApp (Hello, help, general chat). Set false to disable.
ENABLE_WHATSAPP_OPENAI_REPLY=true
# Rewrite verified tank-mix + diagnosis replies in natural language without changing facts (default on)
ENABLE_WHATSAPP_REPLY_POLISH=true
ENABLE_RETENTION_CLEANUP=true
# Farmer + employee opportunity intelligence (nightly IST 02:00ΓÇô04:59)
ENABLE_OPPORTUNITY_SCORE_WORKER=true
# Educational WhatsApp during low-score nurture batch
ENABLE_OPPORTUNITY_NURTURE_WHATSAPP=true
# WhatsApp proactive broadcasts (Scenarios 21ΓÇô24); IST 07:00ΓÇô09:59 window
ENABLE_WHATSAPP_BROADCASTS=true
# Daily Market Insights PNG to all farmers (WhatsApp Cloud only)
ENABLE_MARKET_INSIGHT_IMAGE_BROADCAST=false
# Auto-fetch prices + insights per farmer PIN via OpenAI (one call per pincode/day, cached)
ENABLE_MARKET_INSIGHT_OPENAI=true
MARKET_INSIGHT_BUILD_HOUR_IST=11
MARKET_INSIGHT_SEND_HOUR_IST=12
WHATSAPP_BROADCAST_MAX_PER_DAY=2
WHATSAPP_BROADCAST_KIND_COOLDOWN_HOURS=72
# Order dispatched + payment failed WhatsApp alerts (Scenarios 35ΓÇô36)
ENABLE_WHATSAPP_ORDER_ALERTS=true
SHOPIFY_STOREFRONT_URL=https://morbeez.myshopify.com
# Cultivation logging follow-ups (Scenarios 30ΓÇô31, 37)
ENABLE_CULTIVATION_FOLLOW_UPS=true
CULTIVATION_APPLICATION_DAYS=5
CULTIVATION_RESULT_DAYS=10
# Reuse prior successful advisories for same crop/symptom/DAP/district (Scenario 38)
ENABLE_AI_REUSE_CACHE=true
# Expert Copilot phased rollout (all replacement paths default off in code)
ENABLE_EXPERT_CASES=false
ENABLE_EXPERT_CASE_DEDUPE=false
ENABLE_EXPERT_CASE_RECURRENCE=false
ENABLE_EXPERT_CASE_OWNERSHIP=false
ENABLE_EXPERT_CASE_VERSION_LOCK=false
ENABLE_EXPERT_COPILOT_QUEUE=false
ENABLE_EXPERT_COPILOT_AUTO_ASSIGN=false
ENABLE_EXPERT_COPILOT_LEASE_REAPER=false
ENABLE_EXPERT_COPILOT_CHAT=false
ENFORCE_SERVER_RECOMMENDATION_SAFETY=false
ENABLE_EXPERT_COMMIT_RPCS=false
ENABLE_RECOMMENDATION_COMMUNICATION_OUTBOX=false
ENABLE_LEARNING_CANDIDATE_SHADOW=false
DISABLE_LEGACY_AUTO_PROMOTION=false
ENABLE_APPROVED_REUSE_MEMORY_READ=false
ENFORCE_GOVERNANCE_AUDIT=false
ENABLE_REVIEWER_RISK_MONITORING=false
EXPERT_CASE_LEASE_SECONDS=900
EXPERT_CASE_RECURRENCE_DAYS=14
EXPERT_CASE_INTERRUPTION_LIMIT=2
# Similar verified cases ΓåÆ sequential WhatsApp follow-ups before Crop Doctor
# Expert-approved cases save follow-up questions to learned_follow_up_questions (reused as-is)
ENABLE_DIAGNOSIS_FOLLOW_UP=true
DIAGNOSIS_FOLLOW_UP_MAX_QUESTIONS=3
DIAGNOSIS_FOLLOW_UP_MIN_CASES=1
DIAGNOSIS_FOLLOW_UP_STRONG_MATCH=0.9
# Regional terminology: detect unknown village words, escalate, localize replies
ENABLE_REGIONAL_TERMINOLOGY_ENGINE=true

# M3 ΓÇö AI Crop Doctor (full diagnosis for detailed symptoms + images)
ENABLE_AI_CROP_DOCTOR=true
ENABLE_ADVISORY_FOLLOW_UPS=true
ENABLE_ADVISORY_AUTOMATION=true
# Outcome KPI follow-up (days after spray confirmation) — learning loop days 7 & 14
REC_FOLLOWUP_OUTCOME_DAYS=7
REC_FOLLOWUP_OUTCOME_SECOND_DAYS=14
REC_FOLLOWUP_OUTCOME_REMINDER_DAYS=2
REC_FOLLOWUP_MAX_OUTCOME_REMINDERS=2
REC_FOLLOWUP_OUTCOME_NO_RESPONSE_DAYS=3
REC_OUTCOME_QA_SAMPLE_PCT=5
AI_ESCALATION_THRESHOLD=0.65
# Per-farmer WhatsApp AI daily caps (set ENABLE_AI_DAILY_LIMITS=true to enforce)
ENABLE_AI_DAILY_LIMITS=false
AI_DAILY_TEXT_LIMIT_FREE=10
AI_DAILY_TEXT_LIMIT_PREMIUM=100
AI_DAILY_IMAGE_LIMIT_FREE=3
AI_DAILY_IMAGE_LIMIT_PREMIUM=50
AI_DAILY_VOICE_LIMIT_FREE=5
AI_DAILY_VOICE_LIMIT_PREMIUM=30
AI_MAX_VOICE_DURATION_SEC=60
AI_MIN_REQUEST_INTERVAL_SEC=30

# Farmer mobile production
AUTH_RATE_LIMIT_MAX=20
FARMER_SCAN_DAILY_QUOTA=20
UPLOAD_BODY_LIMIT_BYTES=10485760

# Satellite provider stub (swap SATELLITE_PROVIDER for production vendor)
SATELLITE_PROVIDER=sentinel
SENTINEL_CLIENT_ID=
SENTINEL_CLIENT_SECRET=
# External ML retrain webhook: POST /morbeez-staff/api/v1/os/ml/retrain-webhook
ML_RETRAIN_WEBHOOK_SECRET=
# IoT sensor HTTP webhook: POST /morbeez-staff/api/v1/os/iot/sensor-readings (X-Internal-Api-Key)
IOT_SENSOR_WEBHOOK_ENABLED=true
# Optional MQTT consumer (set IOT_SENSOR_MQTT_ENABLED=true + MQTT_BROKER_URL)
IOT_SENSOR_MQTT_ENABLED=false
MQTT_BROKER_URL=
MQTT_USERNAME=
MQTT_PASSWORD=

# Production deployment (set real values in Render/Vercel .env — never commit secrets)
# API_BASE_URL=https://morbeez-api-5hbx.onrender.com
# CONSOLE_PUBLIC_URL=https://staff.morbeez.com
# ADMIN_UI_ORIGIN=https://staff.morbeez.com,https://www.morbeez.com,https://morbeez.vercel.app
# SHOPIFY_STOREFRONT_URL=https://www.morbeez.com

# MAIOS v12 / v17 reasoning
ENABLE_MAIOS_V12=true
ENABLE_MAIOS_REASONING=true
ENABLE_MAIOS_PREDICTIVE_RISK=true
ENABLE_MAIOS_SUPPLY_INTEL=false
# false = Bayesian posterior drives diagnosis label; true = LLM label only (shadow)
MAIOS_REASONING_SHADOW=true
MAIOS_DISABLE_GENERIC_OUTCOME=true

# Structured field visits / vision
ENABLE_STRUCTURED_FIELD_VISITS=true
ENABLE_STRUCTURED_VISION=true

# WhatsApp UX
WHATSAPP_IMAGE_BATCH_MS=7000
WHATSAPP_TYPING_SIMULATION=true
WHATSAPP_TYPING_MIN_MS=1000
ENABLE_WHATSAPP_ROI=true
ENABLE_ROI_DAILY_PROMPT=true

# Recommendation follow-up windows
REC_FOLLOWUP_APPLICATION_DAYS=1
REC_FOLLOWUP_MAX_REMINDERS=3
REC_FOLLOWUP_NO_RESPONSE_DAYS=3

AI_REVIEW_THRESHOLD=0.8

# Exotel telecaller (optional)
EXOTEL_SID=
EXOTEL_TOKEN=
EXOTEL_CALLER_ID=
EXOTEL_SUBDOMAIN=api.exotel.com

# Optional staff console password gate
# CONSOLE_SHARED_PASSWORD=change_me
