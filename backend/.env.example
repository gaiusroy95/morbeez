# Server
NODE_ENV=development
PORT=3000
API_BASE_URL=https://api-staging.morbeez.in
LOG_LEVEL=info

# Supabase
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_ANON_KEY=eyJ...

# Shopify
SHOPIFY_STORE_DOMAIN=morbeez.myshopify.com
SHOPIFY_ADMIN_API_ACCESS_TOKEN=shpat_...
SHOPIFY_API_VERSION=2024-10
SHOPIFY_WEBHOOK_SECRET=whsec_...
# Partner app (install + app proxy HMAC) — from dev.shopify.com → morbeez → Settings
SHOPIFY_APP_CLIENT_ID=87add483c25cbce127ee00731fb8e5a7
SHOPIFY_APP_CLIENT_SECRET=shpss_...
SHOPIFY_APP_SCOPES=write_app_proxy
# Partner app version URLs (must match):
#   App URL: https://YOUR_API/auth/shopify/installed
#   Allowed redirection URL: https://YOUR_API/auth/shopify/callback

# Outbox retry worker (polls failed events every 30s)
ENABLE_OUTBOX_WORKER=true

# Razorpay
RAZORPAY_KEY_ID=rzp_live_xxx
RAZORPAY_KEY_SECRET=xxx
RAZORPAY_WEBHOOK_SECRET=whsec_razorpay
# Storefront: Razorpay Orders API (cart → /pages/checkout, not Shopify checkout)
ENABLE_RAZORPAY_CHECKOUT=true
CHECKOUT_SUCCESS_PATH=/pages/checkout-success

# Shiprocket
SHIPROCKET_EMAIL=
SHIPROCKET_PASSWORD=
# Same secret you enter in Shiprocket → Webhooks → Auth token (x-api-key)
# Webhook URL must NOT contain "shiprocket", "sr", or "kr" — use:
# https://YOUR_API/webhooks/tracking
SHIPROCKET_WEBHOOK_TOKEN=your_long_random_secret_here

# WhatsApp — provider: cloud (Meta) | adsgyani | wati | interakt
WHATSAPP_PROVIDER=cloud

# ─── Ads Gyani (adsgyani.in) — WA Mantra API v1.0 ───
# Settings → API & Webhook: Base URL, Vendor UID (UUID), API Access Token
# Docs: https://adsgyani.in/api-docs.pdf
ADS_GYANI_API_BASE=https://adsgyani.in/api
ADS_GYANI_TENANT=7f463da3-64ee-4926-949b-450605610908
ADS_GYANI_API_TOKEN=your_64_char_api_access_token
# Webhook: enable in dashboard → POST https://<API_BASE_URL>/webhooks/whatsapp/adsgyani
ADS_GYANI_WEBHOOK_VERIFY_TOKEN=morbeez_adsgyani_verify_change_me
ADS_GYANI_WEBHOOK_SECRET=
ADS_GYANI_SEND_TEXT_PATH=/contact/send-message
ADS_GYANI_SEND_TEMPLATE_PATH=/contact/send-template-message
ADS_GYANI_TEMPLATE_LANGUAGE=en
# Approved template names in Ads Gyani / Meta (required for first contact & outside 24h window)
WHATSAPP_WELCOME_TEMPLATE=
WHATSAPP_OUTBOUND_TEMPLATE=
WHATSAPP_SESSION_HOURS=24
# Public storefront for product links in WhatsApp replies
SHOPIFY_STOREFRONT_URL=https://morbeez.in

# ─── Meta WhatsApp Cloud API (WHATSAPP_PROVIDER=cloud) ───
# Meta App → WhatsApp → Configuration:
#   Callback URL: https://YOUR_API/webhooks/whatsapp
#   Verify token: must match WHATSAPP_VERIFY_TOKEN exactly (copy both sides)
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_VERIFY_TOKEN=morbeez_whatsapp_verify_change_me
WHATSAPP_BUSINESS_ACCOUNT_ID=

# ─── WATI (if WHATSAPP_PROVIDER=wati) ───
WATI_API_ENDPOINT=https://live-mt-server.wati.io
WATI_ACCESS_TOKEN=

# ─── Interakt (if WHATSAPP_PROVIDER=interakt) ───
INTERAKT_API_KEY=

# OpenAI — Crop Doctor (M3)
OPENAI_API_KEY=sk-...
OPENAI_VISION_MODEL=gpt-4o
# Crop Doctor JSON advisory — use gpt-4o (or gpt-4.1). o1/o3 need max_completion_tokens (handled in code) but may not support json_object.
OPENAI_TEXT_MODEL=gpt-4o
OPENAI_WHISPER_MODEL=whisper-1

# Plant.id — supplemental disease signal
PLANT_ID_API_KEY=

# Security
INTERNAL_API_KEY=generate_long_random_key_for_admin_routes
# Website farmer login JWT (min 32 chars — openssl rand -hex 32)
FARMER_JWT_SECRET=5ccc4365fd9dfde4256a0e360a0b6d1a88fae796b10800336d11b475c31adb5d
# Staff admin portal (/admin) — openssl rand -hex 32
ADMIN_JWT_SECRET=change_me_admin_jwt_secret_min_32_chars
# Staff portal public URL (for invite / reset links) — must end with /morbeez-staff (not /console)
CONSOLE_PUBLIC_URL=http://localhost:3000/morbeez-staff
# Production example:
# CONSOLE_PUBLIC_URL=https://morbeez-api.onrender.com/morbeez-staff
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# Feature flags
ENABLE_SHIPROCKET_AUTO_SHIP=true
ENABLE_RAZORPAY_PAYMENT_LINKS=true
ENABLE_WHATSAPP_AUTO_REPLY=false
# OpenAI auto-replies on WhatsApp (Hello, help, general chat). Set false to disable.
ENABLE_WHATSAPP_OPENAI_REPLY=true
# Rewrite verified tank-mix + diagnosis replies in natural language without changing facts (default on)
ENABLE_WHATSAPP_REPLY_POLISH=true
ENABLE_RETENTION_CLEANUP=true
# Farmer + employee opportunity intelligence (nightly IST 02:00–04:59)
ENABLE_OPPORTUNITY_SCORE_WORKER=true
# Educational WhatsApp during low-score nurture batch
ENABLE_OPPORTUNITY_NURTURE_WHATSAPP=true
# WhatsApp proactive broadcasts (Scenarios 21–24); IST 07:00–09:59 window
ENABLE_WHATSAPP_BROADCASTS=true
WHATSAPP_BROADCAST_MAX_PER_DAY=2
WHATSAPP_BROADCAST_KIND_COOLDOWN_HOURS=72
# Order dispatched + payment failed WhatsApp alerts (Scenarios 35–36)
ENABLE_WHATSAPP_ORDER_ALERTS=true
SHOPIFY_STOREFRONT_URL=https://morbeez.myshopify.com
# Cultivation logging follow-ups (Scenarios 30–31, 37)
ENABLE_CULTIVATION_FOLLOW_UPS=true
CULTIVATION_APPLICATION_DAYS=5
CULTIVATION_RESULT_DAYS=10
# Reuse prior successful advisories for same crop/symptom/DAP/district (Scenario 38)
ENABLE_AI_REUSE_CACHE=true
# Similar verified cases → 1–2 WhatsApp follow-ups before Crop Doctor
ENABLE_DIAGNOSIS_FOLLOW_UP=true
DIAGNOSIS_FOLLOW_UP_MAX_QUESTIONS=2
DIAGNOSIS_FOLLOW_UP_MIN_CASES=3
DIAGNOSIS_FOLLOW_UP_STRONG_MATCH=0.88
# Regional terminology: detect unknown village words, escalate, localize replies
ENABLE_REGIONAL_TERMINOLOGY_ENGINE=true

# M3 — AI Crop Doctor (full diagnosis for detailed symptoms + images)
ENABLE_AI_CROP_DOCTOR=true
ENABLE_ADVISORY_FOLLOW_UPS=true
ENABLE_ADVISORY_AUTOMATION=true
# Outcome KPI follow-up (days after spray confirmation)
REC_FOLLOWUP_OUTCOME_DAYS=5
REC_FOLLOWUP_OUTCOME_REMINDER_DAYS=2
REC_FOLLOWUP_MAX_OUTCOME_REMINDERS=2
REC_FOLLOWUP_OUTCOME_NO_RESPONSE_DAYS=3
REC_OUTCOME_QA_SAMPLE_PCT=5
AI_ESCALATION_THRESHOLD=0.65
# Per-farmer WhatsApp AI quotas (free / premium)
AI_DAILY_TEXT_LIMIT_FREE=10
AI_DAILY_TEXT_LIMIT_PREMIUM=100
AI_DAILY_IMAGE_LIMIT_FREE=3
AI_DAILY_IMAGE_LIMIT_PREMIUM=50
AI_DAILY_VOICE_LIMIT_FREE=5
AI_DAILY_VOICE_LIMIT_PREMIUM=30
AI_MAX_VOICE_DURATION_SEC=60
AI_MIN_REQUEST_INTERVAL_SEC=30
