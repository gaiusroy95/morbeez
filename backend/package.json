{
  "name": "@morbeez/api",
  "version": "0.1.0-m3",
  "private": true,
  "type": "module",
  "description": "Morbeez API — commerce, WhatsApp, AI Crop Doctor",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "npm run install:ui && tsc && npm run build:console && npm run build:field",
    "build:api": "tsc",
    "install:ui": "npm install --prefix console-ui --include=dev && npm install --prefix field-pwa --include=dev",
    "build:console": "npm run build --prefix console-ui",
    "build:field": "npm run build --prefix field-pwa",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test tests/**/*.test.ts",
    "lint": "eslint src --ext .ts",
    "db:types": "echo 'Generate types: supabase gen types typescript --local > src/types/database.ts'"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.0",
    "@fastify/helmet": "^13.0.0",
    "@fastify/rate-limit": "^10.0.0",
    "@fastify/static": "^8.0.0",
    "@supabase/supabase-js": "^2.47.0",
    "dotenv": "^16.4.0",
    "fastify": "^5.0.0",
    "pino": "^9.0.0",
    "pino-pretty": "^13.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
