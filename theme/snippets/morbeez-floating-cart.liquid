<a
  href="{{ routes.cart_url }}"
  class="morbeez-floating-cart fixed right-0 top-1/2 z-30 flex -translate-y-1/2 flex-col items-center gap-1 rounded-l-xl bg-[var(--color-primary)] px-2.5 py-4 text-white shadow-lg transition hover:brightness-110 lg:hidden"
  aria-label="{{ 'general.cart' | t }}"
  style="background: var(--gradient-brand);"
>
  {%- render 'morbeez-icon', name: 'cart', class: 'h-6 w-6' -%}
  <span class="text-xs font-bold" data-morbeez-cart-count>{{ cart.item_count }}</span>
</a>
