{% comment %}
  Navigation link — top bar or green nav bar.
  @param {link} link
  @param {string} [variant] - 'light' (green bar) or 'default'
{% endcomment %}
{%- liquid
  assign variant = variant | default: 'brand'
  assign has_children = false
  if link.links.size > 0
    assign has_children = true
  endif
-%}
{%- if has_children -%}
  <div class="morbeez-nav-item group relative shrink-0 px-1.5">
    <a
      href="{{ link.url }}"
      class="morbeez-nav-link flex items-center gap-1 whitespace-nowrap py-2 text-sm font-semibold transition {% if variant == 'light' %}text-white/95 hover:text-white{% else %}text-[var(--color-trust)] hover:text-[var(--color-primary)]{% endif %}"
      data-mega-trigger
      aria-expanded="false"
      aria-haspopup="true"
    >
      {{ link.title }}
      <span class="text-[10px] opacity-70" aria-hidden="true">▾</span>
    </a>
    {%- comment -%} Hover bridge — keeps dropdown open when moving from tab to panel {%- endcomment -%}
    <span class="pointer-events-none absolute left-0 top-full z-[60] hidden h-2 w-full group-hover:block" aria-hidden="true"></span>
    <div
      class="morbeez-mega-panel pointer-events-none invisible absolute left-0 top-[calc(100%+0.25rem)] z-[60] min-w-[16rem] rounded-xl border border-gray-100 bg-white p-5 text-left normal-case opacity-0 shadow-xl transition duration-150 group-hover:pointer-events-auto group-hover:visible group-hover:opacity-100 group-focus-within:pointer-events-auto group-focus-within:visible group-focus-within:opacity-100"
      data-mega-panel
      role="menu"
    >
      <ul class="space-y-1" role="list">
        {%- for child in link.links -%}
          <li>
            <a href="{{ child.url }}" class="block rounded-lg px-3 py-2 text-sm font-medium text-[var(--color-trust)] hover:bg-[var(--color-surface)] hover:text-[var(--color-primary)]">
              {{ child.title }}
            </a>
            {%- if child.links.size > 0 -%}
              <ul class="ml-3 border-l border-[var(--color-border)] py-1 pl-3" role="list">
                {%- for grandchild in child.links -%}
                  <li>
                    <a href="{{ grandchild.url }}" class="block py-1.5 text-xs text-[var(--color-muted)] hover:text-[var(--color-primary)]">
                      {{ grandchild.title }}
                    </a>
                  </li>
                {%- endfor -%}
              </ul>
            {%- endif -%}
          </li>
        {%- endfor -%}
      </ul>
      <a href="{{ link.url }}" class="mt-3 inline-block text-xs font-bold text-[var(--color-primary)]">
        {{ 'general.view_all' | t }} {{ link.title }} →
      </a>
    </div>
  </div>
{%- else -%}
  <a
    href="{{ link.url }}"
    class="morbeez-nav-link shrink-0 whitespace-nowrap px-2 py-2 text-sm font-semibold transition {% if variant == 'light' %}text-white/95 hover:text-white{% else %}text-[var(--color-trust)] hover:text-[var(--color-primary)]{% endif %}"
  >
    {{ link.title }}
  </a>
{%- endif -%}
