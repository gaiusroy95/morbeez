{%- assign faq_items = product.metafields.morbeez.faq.value -%}
{%- if faq_items and faq_items.size > 0 -%}
<script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {%- for item in faq_items -%}
        {
          "@type": "Question",
          "name": {{ item.q | json }},
          "acceptedAnswer": {
            "@type": "Answer",
            "text": {{ item.a | json }}
          }
        }{% unless forloop.last %},{% endunless %}
      {%- endfor -%}
    ]
  }
</script>
{%- endif -%}
