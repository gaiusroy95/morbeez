{% comment %}
  Product rating — Shopify Product Reviews / Judge.me metafields, or morbeez.rating.
  @param {product} product
  @param {string} [class]
{% endcomment %}
{%- liquid
  assign rating = product.metafields.reviews.rating.value.rating | default: product.metafields.reviews.rating.value | default: product.metafields.morbeez.rating
  assign count = product.metafields.reviews.rating_count | default: product.metafields.morbeez.rating_count
-%}
{%- if rating != blank -%}
  {%- assign rating_num = rating | plus: 0 | round -%}
  <div class="flex items-center gap-1.5 {{ class }}" aria-label="{{ rating_num }} out of 5{% if count != blank %}, {{ count }} reviews{% endif %}">
    <span class="flex text-amber-400" aria-hidden="true">
      {%- for i in (1..5) -%}
        {%- if i <= rating_num -%}
          <svg class="h-3.5 w-3.5 fill-current" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
        {%- else -%}
          <svg class="h-3.5 w-3.5 text-gray-200" viewBox="0 0 20 20" fill="currentColor"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
        {%- endif -%}
      {%- endfor -%}
    </span>
    {%- if count != blank -%}
      <span class="text-xs text-[var(--color-muted)]">({{ count }})</span>
    {%- endif -%}
  </div>
{%- endif -%}
