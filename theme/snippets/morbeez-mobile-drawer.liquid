{% comment %}
  Mobile navigation drawer
  @param {string} menu - main link_list handle
  @param {string} [utility_menu] - secondary links (FAQ, careers, etc.)
  @param {boolean} [show_login]
  @param {string} [login_url]
  @param {string} [login_label]
{% endcomment %}
<div
  id="morbeez-mobile-drawer"
  class="morbeez-drawer fixed inset-0 z-[60] hidden"
  aria-hidden="true"
  data-mobile-drawer
>
  <div class="absolute inset-0 bg-[var(--color-trust)]/50 backdrop-blur-sm" data-drawer-backdrop></div>
  <nav
    class="absolute right-0 top-0 flex h-full w-[min(100%,20rem)] flex-col bg-white shadow-2xl sm:w-[22rem]"
    role="dialog"
    aria-modal="true"
    aria-label="{{ 'accessibility.mobile_navigation' | t }}"
  >
    <div class="flex items-center justify-between border-b border-[var(--color-border)] bg-white px-4 py-3">
      {%- render 'morbeez-logo', class: 'max-w-[160px]' -%}
      <button type="button" class="morbeez-icon-btn text-white hover:bg-white/10" data-drawer-close aria-label="{{ 'accessibility.close' | t }}">
        {%- render 'morbeez-icon', name: 'close', class: 'h-5 w-5' -%}
      </button>
    </div>

    <div class="border-b border-[var(--color-border)] p-4">
      {%- render 'morbeez-header-search' -%}
    </div>

    <div class="flex-1 overflow-y-auto p-3">
      <p class="mb-2 px-2 text-[10px] font-bold uppercase tracking-wider text-[var(--color-muted)]">{{ 'header.menu_main' | t }}</p>
      <ul class="space-y-0.5" role="list">
        {%- assign nav_menu = linklists[menu] -%}
        {%- assign min_nav = 6 -%}
        {%- if nav_menu.links.size >= min_nav -%}
          {%- for link in nav_menu.links -%}
            <li>
              {%- if link.links.size > 0 -%}
                <details class="group rounded-lg">
                  <summary class="flex cursor-pointer list-none items-center justify-between rounded-lg px-3 py-3 text-sm font-bold uppercase tracking-wide text-[var(--color-trust)] hover:bg-[var(--color-surface)]">
                    {{ link.title }}
                    {%- render 'morbeez-icon', name: 'chevron-down', class: 'h-4 w-4' -%}
                  </summary>
                  <ul class="ml-2 space-y-0.5 border-l-2 border-[var(--color-primary)]/20 py-2 pl-3" role="list">
                    {%- for child in link.links -%}
                      <li>
                        <a href="{{ child.url }}" class="block rounded-lg px-3 py-2 text-sm text-[var(--color-muted)] hover:text-[var(--color-primary)]">{{ child.title }}</a>
                      </li>
                    {%- endfor -%}
                  </ul>
                </details>
              {%- else -%}
                <a href="{{ link.url }}" class="block rounded-lg px-3 py-3 text-sm font-bold uppercase tracking-wide text-[var(--color-trust)] hover:bg-[var(--color-surface)]">{{ link.title }}</a>
              {%- endif -%}
            </li>
          {%- endfor -%}
        {%- else -%}
          {%- render 'morbeez-fallback-nav', variant: 'mobile' -%}
        {%- endif -%}
      </ul>

      {%- assign util = linklists[utility_menu] -%}
      {%- if util.links.size > 0 -%}
        <p class="mb-2 mt-6 px-2 text-[10px] font-bold uppercase tracking-wider text-[var(--color-muted)]">{{ 'header.menu_more' | t }}</p>
        <ul class="space-y-0.5" role="list">
          {%- for link in util.links -%}
            <li>
              <a href="{{ link.url }}" class="block rounded-lg px-3 py-2.5 text-sm font-medium text-[var(--color-muted)] hover:text-[var(--color-primary)]">{{ link.title }}</a>
            </li>
          {%- endfor -%}
        </ul>
      {%- endif -%}
    </div>

    <div class="space-y-2 border-t border-[var(--color-border)] p-4">
      {%- if show_login -%}
        <a
          href="{{ login_url | default: '/pages/login' }}"
          data-morbeez-login-link
          data-login-href="{{ login_url | default: '/pages/login' }}"
          data-login-label="{{ login_label | default: 'Login' }}"
          class="morbeez-btn-primary w-full justify-center border-0 text-center text-sm uppercase tracking-wide"
        >
          {{ login_label | default: 'Login' }}
        </a>
      {%- endif -%}
      <a href="{{ routes.cart_url }}" class="morbeez-btn-secondary w-full justify-center text-center text-sm">
        {{ 'general.cart' | t }} · {%- render 'morbeez-money', amount: cart.total_price, plain: true -%}
      </a>
    </div>
  </nav>
</div>
