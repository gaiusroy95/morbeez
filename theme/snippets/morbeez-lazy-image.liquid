{% comment %}
  Responsive image with lazy loading.
  Accepts: image, alt, widths (comma string), sizes, loading, class, fetchpriority
{% endcomment %}
{%- if image != blank -%}
  {%- assign width_list = widths | default: '360,540,720,1080' | split: ',' -%}
  {%- capture srcset -%}
    {%- for w in width_list -%}
      {{ image | image_url: width: w | strip }} {{ w | strip }}w{%- unless forloop.last -%}, {%- endunless -%}
    {%- endfor -%}
  {%- endcapture -%}
  <img
    src="{{ image | image_url: width: 720 }}"
    srcset="{{ srcset }}"
    sizes="{{ sizes | default: '100vw' }}"
    alt="{{ alt | default: image.alt | escape }}"
    width="{{ image.width }}"
    height="{{ image.height }}"
    loading="{{ loading | default: 'lazy' }}"
    {% if fetchpriority %}fetchpriority="{{ fetchpriority }}"{% endif %}
    {% if id %}id="{{ id }}"{% endif %}
    class="{{ class }}"
  >
{%- endif -%}
