{%- liquid
  assign fetch = 'high'
  assign loading = 'eager'
-%}

<section
  class="relative overflow-hidden morbeez-section--tight lg:morbeez-section"
  id="MorbeezHero-{{ section.id }}"
  style="background: var(--gradient-hero);"
>
  <div class="pointer-events-none absolute inset-0 overflow-hidden" aria-hidden="true">
    <div class="absolute -left-32 top-20 h-96 w-96 rounded-full bg-[var(--color-primary)]/5 blur-3xl"></div>
    <div class="absolute -right-24 bottom-0 h-80 w-80 rounded-full bg-[var(--color-accent)]/10 blur-3xl"></div>
  </div>

  <div class="morbeez-container relative">
    <div class="grid items-center gap-10 lg:grid-cols-2 lg:gap-16">
      <div class="order-2 lg:order-1">
        {%- if section.settings.badge != blank -%}
          <span class="mb-4 inline-flex items-center gap-2 rounded-full border border-[var(--color-primary)]/15 bg-white/80 px-4 py-1.5 text-xs font-semibold text-[var(--color-primary)] backdrop-blur-sm">
            {%- render 'morbeez-icon', name: 'leaf', class: 'h-3.5 w-3.5' -%}
            {{ section.settings.badge }}
          </span>
        {%- endif -%}
        <h1 class="font-heading text-4xl font-bold leading-[1.1] tracking-tight text-[var(--color-trust)] sm:text-5xl lg:text-[3.25rem]">
          {{ section.settings.heading }}
        </h1>
        {%- if section.settings.subheading != blank -%}
          <div class="mt-5 max-w-lg text-lg leading-relaxed text-[var(--color-muted)]">
            {{ section.settings.subheading }}
          </div>
        {%- endif -%}
        <div class="mt-8 flex flex-wrap gap-3">
          {%- if section.settings.primary_cta_url != blank -%}
            {%- render 'morbeez-button',
              url: section.settings.primary_cta_url,
              label: section.settings.primary_cta_label,
              style: 'primary',
              show_arrow: true
            -%}
          {%- endif -%}
          {%- if section.settings.secondary_cta_url != blank -%}
            {%- render 'morbeez-button',
              url: section.settings.secondary_cta_url,
              label: section.settings.secondary_cta_label,
              style: 'secondary'
            -%}
          {%- endif -%}
        </div>
        {%- if section.blocks.size > 0 -%}
          <ul class="mt-10 grid gap-3 sm:grid-cols-2" role="list">
            {%- for block in section.blocks -%}
              <li
                class="flex items-center gap-3 rounded-xl border border-[var(--color-border)] bg-white/70 px-4 py-3 backdrop-blur-sm"
                {{ block.shopify_attributes }}
              >
                {%- if block.settings.icon != blank -%}
                  {{ block.settings.icon | image_url: width: 40 | image_tag: widths: '40', class: 'h-10 w-10 rounded-lg object-cover' }}
                {%- else -%}
                  <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-[var(--color-primary)]/10 text-[var(--color-primary)]">
                    {%- render 'morbeez-icon', name: 'leaf', class: 'h-5 w-5' -%}
                  </span>
                {%- endif -%}
                <span class="text-sm font-medium text-[var(--color-trust)]">{{ block.settings.text }}</span>
              </li>
            {%- endfor -%}
          </ul>
        {%- endif -%}
      </div>
      <div class="order-1 lg:order-2">
        {%- liquid
          assign hero_image = section.settings.image
          if section.settings.image_mobile != blank
            assign hero_image_mobile = section.settings.image_mobile
          else
            assign hero_image_mobile = section.settings.image
          endif
        -%}
        {%- if hero_image != blank -%}
          <div class="relative">
            <div class="absolute -inset-3 rounded-3xl bg-[var(--gradient-brand)] opacity-10 blur-2xl" aria-hidden="true"></div>
            <div class="relative overflow-hidden rounded-3xl shadow-[var(--shadow-lg)] ring-1 ring-black/5">
              {%- if section.settings.overlay_opacity > 0 -%}
                <div
                  class="pointer-events-none absolute inset-0 z-10"
                  style="background: linear-gradient(to top, rgba(0,0,0,{{ section.settings.overlay_opacity | divided_by: 100.0 }}), transparent 50%);"
                  aria-hidden="true"
                ></div>
              {%- endif -%}
              <picture>
                {%- if section.settings.image_mobile != blank -%}
                  <source media="(max-width: 1023px)" srcset="{{ hero_image_mobile | image_url: width: 800 }}">
                {%- endif -%}
                {%- render 'morbeez-lazy-image',
                  image: hero_image,
                  alt: section.settings.heading,
                  loading: loading,
                  fetchpriority: fetch,
                  class: 'aspect-[4/3] w-full object-cover lg:aspect-[5/4]',
                  sizes: '(max-width: 1024px) 100vw, 50vw'
                -%}
              </picture>
            </div>
          </div>
        {%- else -%}
          <div class="flex aspect-[4/3] items-center justify-center rounded-3xl bg-[var(--color-surface)] ring-1 ring-[var(--color-border)]">
            {{ 'lifestyle-1' | placeholder_svg_tag: 'w-2/3 h-auto opacity-40' }}
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "t:sections.hero_premium.name",
  "tag": "section",
  "class": "section-hero-premium",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "t:sections.hero_premium.settings.image" },
    { "type": "image_picker", "id": "image_mobile", "label": "t:sections.hero_premium.settings.image_mobile" },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 60,
      "step": 5,
      "unit": "%",
      "label": "t:sections.hero_premium.settings.overlay_opacity",
      "default": 0
    },
    {
      "type": "text",
      "id": "badge",
      "label": "t:sections.hero_premium.settings.badge",
      "default": "Trusted by farmers across India"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.hero_premium.settings.heading",
      "default": "Premium crop care for every season"
    },
    {
      "type": "richtext",
      "id": "subheading",
      "label": "t:sections.hero_premium.settings.subheading",
      "default": "<p>Shop crop-wise solutions, AI-assisted advisory, and fast delivery — built for Indian agriculture.</p>"
    },
    { "type": "url", "id": "primary_cta_url", "label": "t:sections.hero_premium.settings.primary_cta_url" },
    {
      "type": "text",
      "id": "primary_cta_label",
      "label": "t:sections.hero_premium.settings.primary_cta_label",
      "default": "Shop now"
    },
    { "type": "url", "id": "secondary_cta_url", "label": "t:sections.hero_premium.settings.secondary_cta_url" },
    {
      "type": "text",
      "id": "secondary_cta_label",
      "label": "t:sections.hero_premium.settings.secondary_cta_label",
      "default": "Talk on WhatsApp"
    }
  ],
  "blocks": [
    {
      "type": "trust_badge",
      "name": "t:sections.hero_premium.blocks.trust_badge.name",
      "settings": [
        { "type": "image_picker", "id": "icon", "label": "t:sections.hero_premium.blocks.trust_badge.settings.icon" },
        {
          "type": "text",
          "id": "text",
          "label": "t:sections.hero_premium.blocks.trust_badge.settings.text",
          "default": "Quality assured"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.hero_premium.presets.default",
      "blocks": [
        { "type": "trust_badge", "settings": { "text": "Expert advisory" } },
        { "type": "trust_badge", "settings": { "text": "Fast delivery" } }
      ]
    }
  ]
}
{% endschema %}
