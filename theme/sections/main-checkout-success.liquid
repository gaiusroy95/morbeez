<section class="morbeez-section">
  <div class="morbeez-container max-w-lg text-center">
    <div class="morbeez-card p-10">
      <div class="mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-full bg-green-100 text-3xl text-[var(--color-primary)]">✓</div>
      <h1 class="font-heading text-2xl font-bold">{{ 'checkout.success_title' | t }}</h1>
      <p class="mt-3 text-[var(--color-muted)]">{{ 'checkout.success_message' | t }}</p>
      <p id="order-ref" class="mt-2 hidden font-semibold text-[var(--color-trust)]"></p>
      <a href="{{ routes.root_url }}" class="morbeez-btn-primary mt-8 inline-flex">{{ 'checkout.continue_shopping' | t }}</a>
    </div>
  </div>
</section>
<script>
  (function () {
    var p = new URLSearchParams(window.location.search);
    var order = p.get('order');
    if (order) {
      var el = document.getElementById('order-ref');
      if (el) {
        el.textContent = 'Order ' + order;
        el.classList.remove('hidden');
      }
    }
  })();
</script>
{% schema %}
{
  "name": "Checkout success",
  "settings": [],
  "enabled_on": { "templates": ["page"] }
}
{% endschema %}
