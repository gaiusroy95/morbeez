<section class="morbeez-section" id="MorbeezAdvisory-{{ section.id }}">
  <div class="morbeez-container">
    {%- render 'morbeez-section-header', heading: section.settings.heading, subheading: section.settings.subheading -%}

    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {%- for block in section.blocks -%}
        <a href="{{ block.settings.link }}" class="morbeez-card flex gap-4 p-4 transition hover:border-[var(--color-primary)]" {{ block.shopify_attributes }}>
          <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-lg bg-[var(--color-primary)]/10 text-xl">
            {%- if block.settings.icon != blank -%}
              {{ block.settings.icon | image_url: width: 48 | image_tag: class: 'h-8 w-8 object-contain' }}
            {%- else -%}
              📖
            {%- endif -%}
          </div>
          <div>
            <h3 class="font-semibold text-[var(--color-trust)]">{{ block.settings.title }}</h3>
            {%- if block.settings.excerpt != blank -%}
              <p class="mt-1 text-sm text-[var(--color-muted)]">{{ block.settings.excerpt }}</p>
            {%- endif -%}
            <span class="mt-2 inline-block text-sm font-semibold text-[var(--color-primary)]">{{ 'general.read_more' | t }} →</span>
          </div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "t:sections.advisory_education.name",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "t:sections.advisory_education.settings.heading", "default": "Learn & grow better" },
    { "type": "text", "id": "subheading", "label": "t:sections.advisory_education.settings.subheading", "default": "Expert guides for Indian farmers" }
  ],
  "blocks": [
    {
      "type": "education_card",
      "name": "t:sections.advisory_education.blocks.card.name",
      "settings": [
        { "type": "image_picker", "id": "icon", "label": "t:sections.advisory_education.blocks.card.settings.icon" },
        { "type": "text", "id": "title", "label": "t:sections.advisory_education.blocks.card.settings.title" },
        { "type": "textarea", "id": "excerpt", "label": "t:sections.advisory_education.blocks.card.settings.excerpt" },
        { "type": "url", "id": "link", "label": "t:sections.advisory_education.blocks.card.settings.link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.advisory_education.presets.default",
      "blocks": [
        { "type": "education_card", "settings": { "title": "Dosage guides", "excerpt": "How to apply safely and effectively" } },
        { "type": "education_card", "settings": { "title": "Seasonal planning", "excerpt": "Kharif, rabi & monsoon calendars" } }
      ]
    }
  ]
}
{% endschema %}
