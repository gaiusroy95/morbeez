{%- if settings.enable_ai_crop_doctor_cta -%}
  <section class="morbeez-section" id="MorbeezCropDoctor-{{ section.id }}" data-morbeez-feature="crop-doctor">
    <div class="morbeez-container">
      <div class="morbeez-feature-spotlight text-white">
        <div class="relative z-10 grid gap-8 md:grid-cols-2 md:items-center">
          <div>
            <p class="mb-3 inline-flex items-center gap-2 rounded-full bg-white/15 px-3 py-1 text-xs font-semibold backdrop-blur-sm">
              {%- render 'morbeez-icon', name: 'sparkles', class: 'h-4 w-4' -%}
              AI-assisted advisory
            </p>
            <h2 class="font-heading text-3xl font-bold tracking-tight md:text-4xl">{{ section.settings.heading }}</h2>
            <p class="mt-3 max-w-md text-base leading-relaxed text-white/85">{{ section.settings.body }}</p>
            <p class="mt-2 text-xs text-white/60">With agronomist support when needed — not a guaranteed diagnosis.</p>
          </div>
          <div class="flex flex-col gap-3 sm:flex-row md:justify-end">
            {%- if section.settings.cta_url != blank -%}
              {%- render 'morbeez-button',
                url: section.settings.cta_url,
                label: section.settings.cta_label,
                style: 'ghost',
                show_arrow: true,
                class: '!text-[var(--color-trust)]'
              -%}
            {%- endif -%}
          </div>
        </div>
      </div>
    </div>
  </section>
{%- endif -%}

{% schema %}
{
  "name": "t:sections.ai_crop_doctor.name",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "t:sections.ai_crop_doctor.settings.heading", "default": "AI Crop Doctor" },
    {
      "type": "textarea",
      "id": "body",
      "label": "t:sections.ai_crop_doctor.settings.body",
      "default": "Upload a crop photo, describe symptoms, or send a voice note — get guidance in English or Malayalam."
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "t:sections.ai_crop_doctor.settings.cta_url",
      "info": "Link to /pages/crop-doctor"
    },
    { "type": "text", "id": "cta_label", "label": "t:sections.ai_crop_doctor.settings.cta_label", "default": "Try Crop Doctor" }
  ],
  "presets": [{ "name": "t:sections.ai_crop_doctor.presets.default" }]
}
{% endschema %}
