{%- if section.settings.message != blank -%}
  <div
    class="relative overflow-hidden px-4 py-2.5 text-center text-sm font-medium text-white"
    style="background: var(--gradient-brand);"
    role="region"
    aria-label="{{ 'sections.announcement.name' | t }}"
  >
    <div class="pointer-events-none absolute inset-0 bg-[url('data:image/svg+xml,%3Csvg width=\"60\" height=\"60\" viewBox=\"0 0 60 60\" xmlns=\"http://www.w3.org/2000/svg\"%3E%3Cg fill=\"none\" fill-rule=\"evenodd\"%3E%3Cg fill=\"%23ffffff\" fill-opacity=\"0.04\"%3E%3Cpath d=\"M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z\"/%3E%3C/g%3E%3C/g%3E%3C/svg%3E')] opacity-50" aria-hidden="true"></div>
    <div class="relative">
      {%- if section.settings.link != blank -%}
        <a href="{{ section.settings.link }}" class="inline-flex items-center justify-center gap-2 hover:underline">
          {{ section.settings.message }}
          {%- render 'morbeez-icon', name: 'arrow-right', class: 'h-4 w-4' -%}
        </a>
      {%- else -%}
        {{ section.settings.message }}
      {%- endif -%}
    </div>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "t:sections.announcement.name",
  "settings": [
    {
      "type": "text",
      "id": "message",
      "label": "t:sections.announcement.settings.message",
      "default": "Free crop advisory on WhatsApp — expert-backed support for every farmer"
    },
    { "type": "url", "id": "link", "label": "t:sections.announcement.settings.link" }
  ]
}
{% endschema %}
