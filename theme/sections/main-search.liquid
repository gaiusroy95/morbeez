<div class="morbeez-container morbeez-section">
  <h1 class="font-heading text-3xl font-bold">{{ 'general.search' | t }}</h1>

  <form action="{{ routes.search_url }}" method="get" role="search" class="mt-6 flex gap-2">
    <input type="hidden" name="type" value="product">
    <input
      type="search"
      name="q"
      value="{{ search.terms | escape }}"
      placeholder="{{ 'search.placeholder' | t }}"
      class="flex-1 rounded-lg border border-gray-200 p-3 text-sm"
    >
    <button type="submit" class="morbeez-btn-primary border-0">{{ 'search.submit' | t }}</button>
  </form>

  {%- if search.performed -%}
    {%- paginate search.results by section.settings.results_per_page -%}
      <p class="mt-4 text-sm text-[var(--color-muted)]">
        {{ 'search.results_count' | t: count: search.results_count, terms: search.terms }}
        {%- if paginate.pages > 1 -%}
          · {{ 'general.pagination.page' | t: page: paginate.current_page }} / {{ paginate.pages }}
        {%- endif -%}
      </p>

      {%- assign product_results = search.results | where: 'object_type', 'product' -%}
      {%- if product_results.size > 0 -%}
        <div class="mt-8 grid grid-cols-2 gap-4 md:grid-cols-3 lg:grid-cols-4 lg:gap-6">
          {%- for item in search.results -%}
            {%- if item.object_type == 'product' -%}
              {%- render 'morbeez-product-card', product: item -%}
            {%- endif -%}
          {%- endfor -%}
        </div>
        {%- render 'morbeez-pagination', paginate: paginate, item_label: 'results' -%}
      {%- else -%}
        <p class="mt-8 text-center text-[var(--color-muted)]">{{ 'search.no_results' | t }}</p>
      {%- endif -%}
    {%- endpaginate -%}
  {%- endif -%}
</div>

{% schema %}
{
  "name": "t:sections.main_search.name",
  "settings": [
    {
      "type": "range",
      "id": "results_per_page",
      "min": 12,
      "max": 48,
      "step": 4,
      "default": 24,
      "label": "t:sections.main_search.settings.results_per_page"
    }
  ]
}
{% endschema %}
