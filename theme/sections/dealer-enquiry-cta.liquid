{%- if settings.enable_dealer_enquiry -%}
  <section class="morbeez-section--tight" id="MorbeezDealer-{{ section.id }}" data-morbeez-feature="dealer-enquiry">
    <div class="morbeez-container">
      <div class="morbeez-panel flex flex-col items-center gap-6 bg-[var(--color-surface)] text-center md:flex-row md:text-left">
        <div class="flex h-14 w-14 shrink-0 items-center justify-center rounded-2xl bg-[var(--color-primary)]/10 text-[var(--color-primary)]">
          {%- render 'morbeez-icon', name: 'leaf', class: 'h-7 w-7' -%}
        </div>
        <div class="flex-1">
          <h2 class="font-heading text-2xl font-bold tracking-tight text-[var(--color-trust)] md:text-3xl">
            {{ section.settings.heading }}
          </h2>
          <p class="mt-2 text-[var(--color-muted)]">{{ section.settings.body }}</p>
        </div>
        {%- if section.settings.cta_url != blank -%}
          {%- render 'morbeez-button',
            url: section.settings.cta_url,
            label: section.settings.cta_label,
            style: 'primary',
            show_arrow: true
          -%}
        {%- endif -%}
      </div>
    </div>
  </section>
{%- endif -%}

{% schema %}
{
  "name": "t:sections.dealer_enquiry.name",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "t:sections.dealer_enquiry.settings.heading", "default": "Become a Morbeez dealer" },
    {
      "type": "textarea",
      "id": "body",
      "label": "t:sections.dealer_enquiry.settings.body",
      "default": "Wholesale pricing, territory support, and co-branded farmer outreach."
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "t:sections.dealer_enquiry.settings.cta_url",
      "info": "Link to /pages/dealer-enquiry"
    },
    { "type": "text", "id": "cta_label", "label": "t:sections.dealer_enquiry.settings.cta_label", "default": "Partner with us" }
  ],
  "presets": [{ "name": "t:sections.dealer_enquiry.presets.default" }]
}
{% endschema %}
