{%- if collection.image or collection.description != blank -%}
  <div class="border-b border-gray-100 bg-[var(--color-surface)]">
    <div class="morbeez-container py-8 md:py-12">
      {%- render 'morbeez-breadcrumbs' -%}
      <div class="grid items-center gap-6 md:grid-cols-2">
        <div>
          <h1 class="font-heading text-3xl font-bold text-[var(--color-trust)]">{{ collection.title }}</h1>
          {%- if collection.description != blank -%}
            <div class="mt-3 prose prose-sm max-w-none text-[var(--color-muted)]">{{ collection.description }}</div>
          {%- endif -%}
          <p class="mt-2 text-sm text-[var(--color-muted)]">{{ collection.products_count }} {{ 'collections.products_count' | t }}</p>
        </div>
        {%- if collection.image -%}
          <div class="overflow-hidden rounded-xl">
            {%- render 'morbeez-lazy-image', image: collection.image, alt: collection.title, class: 'w-full h-auto max-h-64 object-cover' -%}
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
{%- else -%}
  <div class="morbeez-container py-8">
    {%- render 'morbeez-breadcrumbs' -%}
    <h1 class="font-heading text-3xl font-bold">{{ collection.title }}</h1>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "t:sections.collection_banner.name",
  "settings": []
}
{% endschema %}
