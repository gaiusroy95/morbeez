<div class="morbeez-container morbeez-section">
  <h1 class="font-heading text-3xl font-bold">{{ blog.title }}</h1>
  {%- if blog.description != blank -%}
    <p class="mt-2 text-[var(--color-muted)]">{{ blog.description }}</p>
  {%- endif -%}

  <div class="mt-10 grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
    {%- for article in blog.articles -%}
      <article class="morbeez-card overflow-hidden">
        <a href="{{ article.url }}">
          {%- if article.image -%}
            {%- render 'morbeez-lazy-image', image: article.image, alt: article.title, class: 'w-full aspect-[16/10] object-cover' -%}
          {%- endif -%}
          <div class="p-4">
            <h2 class="font-semibold hover:text-[var(--color-primary)]">{{ article.title }}</h2>
            <p class="mt-2 text-sm text-[var(--color-muted)]">{{ article.excerpt | strip_html | truncate: 100 }}</p>
          </div>
        </a>
      </article>
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "t:sections.main_blog.name",
  "settings": []
}
{% endschema %}
