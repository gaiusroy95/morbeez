<footer class="mt-auto border-t border-[var(--color-border)] bg-[var(--color-trust)] text-white morbeez-section--tight" role="contentinfo">
  <div class="morbeez-container">
    <div class="grid gap-10 md:grid-cols-2 lg:grid-cols-12 lg:gap-8">
      <div class="lg:col-span-3">
        {%- liquid
          assign footer_logo_img = section.settings.footer_logo
          assign footer_on_dark = true
          if footer_logo_img != blank
            assign footer_on_dark = false
          endif
        -%}
        {%- render 'morbeez-logo',
          class: 'morbeez-logo--footer',
          on_dark: footer_on_dark,
          logo_override: footer_logo_img
        -%}
        <p class="mt-3 max-w-sm text-sm leading-relaxed text-white/70">{{ section.settings.tagline }}</p>
        {%- render 'morbeez-social-links',
          facebook: section.settings.social_facebook,
          instagram: section.settings.social_instagram,
          youtube: section.settings.social_youtube,
          linkedin: section.settings.social_linkedin,
          twitter: section.settings.social_twitter,
          class: 'mt-5'
        -%}
        {%- if settings.whatsapp_phone != blank -%}
          <a
            href="https://wa.me/{{ settings.whatsapp_phone | remove: '+' | remove: ' ' }}"
            class="mt-4 inline-flex items-center gap-2 rounded-xl bg-white/10 px-4 py-2.5 text-sm font-medium text-white transition hover:bg-white/15"
            target="_blank"
            rel="noopener noreferrer"
          >
            {%- render 'morbeez-icon', name: 'whatsapp', class: 'h-5 w-5' -%}
            {{ 'general.whatsapp.label' | t }}
          </a>
        {%- endif -%}
      </div>

      {%- for block in section.blocks -%}
        {%- if block.type == 'menu' -%}
          <div class="lg:col-span-2" {{ block.shopify_attributes }}>
            <h3 class="text-xs font-semibold uppercase tracking-wider text-white/50">{{ block.settings.heading }}</h3>
            {%- assign footer_menu = linklists[block.settings.menu] -%}
            {%- if footer_menu.links.size > 0 -%}
              <ul class="mt-4 space-y-2.5" role="list">
                {%- for link in footer_menu.links -%}
                  <li>
                    <a href="{{ link.url }}" class="text-sm text-white/80 transition hover:text-[var(--color-accent)]">{{ link.title }}</a>
                  </li>
                {%- endfor -%}
              </ul>
            {%- elsif block.settings.fallback == 'categories' -%}
              {%- render 'morbeez-fallback-nav', variant: 'footer-categories' -%}
            {%- else -%}
              {%- render 'morbeez-fallback-nav', variant: 'footer-navigate' -%}
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endfor -%}

      {%- if section.settings.show_contact_column -%}
        <div class="lg:col-span-3">
          <h3 class="text-xs font-semibold uppercase tracking-wider text-white/50">{{ section.settings.contact_heading }}</h3>
          <ul class="mt-4 space-y-3 text-sm text-white/80">
            {%- assign addr = section.settings.contact_address | default: settings.store_address -%}
            {%- assign phone = section.settings.contact_phone | default: settings.store_phone -%}
            {%- assign email = section.settings.contact_email | default: settings.store_email -%}
            {%- if addr != blank -%}
              <li>{{ addr }}</li>
            {%- endif -%}
            {%- if phone != blank -%}
              <li><a href="tel:{{ phone | remove: ' ' }}" class="hover:text-[var(--color-accent)]">{{ phone }}</a></li>
            {%- endif -%}
            {%- if email != blank -%}
              <li><a href="mailto:{{ email }}" class="hover:text-[var(--color-accent)]">{{ email }}</a></li>
            {%- endif -%}
            <li><a href="/pages/contact" class="font-medium text-[var(--color-accent)] hover:underline">{{ 'header.menu_contact' | t }}</a></li>
          </ul>
          {%- if section.settings.show_app_promo and section.settings.app_promo_text != blank -%}
            <p class="mt-5 rounded-xl bg-white/5 px-4 py-3 text-xs text-white/60">{{ section.settings.app_promo_text }}</p>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>

    {%- if section.settings.show_newsletter -%}
      <div class="mt-10 border-t border-white/10 pt-8">
        <p class="text-sm font-semibold text-white">{{ section.settings.newsletter_heading }}</p>
        {%- form 'customer', class: 'mt-3 flex max-w-md flex-col gap-2 sm:flex-row' -%}
          <input type="hidden" name="contact[tags]" value="newsletter">
          <input type="email" name="contact[email]" placeholder="{{ 'sections.newsletter.email_label' | t }}" class="min-w-0 flex-1 rounded-lg border-0 bg-white/10 px-3 py-2 text-sm text-white placeholder:text-white/50" required>
          <button type="submit" class="rounded-lg bg-[var(--color-primary)] px-4 py-2 text-sm font-bold text-white">{{ 'sections.newsletter.subscribe' | t }}</button>
        {%- endform -%}
      </div>
    {%- endif -%}

    <div class="mt-12 flex flex-col items-center justify-between gap-4 border-t border-white/10 pt-8 sm:flex-row">
      <p class="text-xs text-white/50">&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.</p>
      <div class="text-white/80">
        {%- render 'morbeez-language-switcher' -%}
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "t:sections.footer.name",
  "settings": [
    {
      "type": "image_picker",
      "id": "footer_logo",
      "label": "t:sections.footer.settings.footer_logo",
      "info": "t:sections.footer.settings.footer_logo_info"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "t:sections.footer.settings.tagline",
      "default": "Science-backed agriculture solutions for every farmer."
    },
    {
      "type": "header",
      "content": "t:sections.footer.settings.contact_header"
    },
    {
      "type": "checkbox",
      "id": "show_contact_column",
      "label": "t:sections.footer.settings.show_contact_column",
      "default": true
    },
    {
      "type": "text",
      "id": "contact_heading",
      "label": "t:sections.footer.settings.contact_heading",
      "default": "Contact us"
    },
    { "type": "textarea", "id": "contact_address", "label": "t:sections.footer.settings.contact_address" },
    { "type": "text", "id": "contact_phone", "label": "t:sections.footer.settings.contact_phone" },
    { "type": "text", "id": "contact_email", "label": "t:sections.footer.settings.contact_email" },
    {
      "type": "header",
      "content": "t:sections.footer.settings.social_header"
    },
    { "type": "url", "id": "social_facebook", "label": "Facebook" },
    { "type": "url", "id": "social_instagram", "label": "Instagram" },
    { "type": "url", "id": "social_youtube", "label": "YouTube" },
    { "type": "url", "id": "social_linkedin", "label": "LinkedIn" },
    { "type": "url", "id": "social_twitter", "label": "X (Twitter)" },
    {
      "type": "header",
      "content": "t:sections.footer.settings.newsletter_header"
    },
    {
      "type": "checkbox",
      "id": "show_newsletter",
      "label": "t:sections.footer.settings.show_newsletter",
      "default": false
    },
    {
      "type": "text",
      "id": "newsletter_heading",
      "label": "t:sections.footer.settings.newsletter_heading",
      "default": "Subscribe for crop tips & offers"
    },
    {
      "type": "checkbox",
      "id": "show_app_promo",
      "label": "t:sections.footer.settings.show_app_promo",
      "default": false
    },
    {
      "type": "text",
      "id": "app_promo_text",
      "label": "t:sections.footer.settings.app_promo_text",
      "default": "Morbeez mobile app — coming soon on Play Store & App Store"
    }
  ],
  "blocks": [
    {
      "type": "menu",
      "name": "t:sections.footer.blocks.menu.name",
      "settings": [
        { "type": "text", "id": "heading", "label": "t:sections.footer.blocks.menu.settings.heading", "default": "Shop" },
        { "type": "link_list", "id": "menu", "label": "t:sections.footer.blocks.menu.settings.menu" },
        {
          "type": "select",
          "id": "fallback",
          "label": "t:sections.footer.blocks.menu.settings.fallback",
          "options": [
            { "value": "navigate", "label": "Navigate (pages, policies)" },
            { "value": "categories", "label": "Product categories" }
          ],
          "default": "navigate",
          "info": "t:sections.footer.blocks.menu.settings.fallback_info"
        }
      ]
    }
  ],
  "presets": [{ "name": "t:sections.footer.presets.default" }]
}
{% endschema %}
