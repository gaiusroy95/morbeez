{% comment %}
  Redirects to Morbeez staff console on the API server (not Shopify Admin).
  Page handle: console · Template: page.console
  Store URL /console → set via Admin URL redirect (npm run setup:pages)
{% endcomment %}
{%- assign console_url = settings.morbeez_api_base_url | default: 'https://morbeez-api.onrender.com' | append: '/console/' -%}
<div class="morbeez-container py-16 text-center">
  <p class="text-[var(--color-muted)]">Redirecting to Morbeez Staff Console…</p>
  <p class="mt-4">
    <a href="{{ console_url }}" class="font-semibold text-[var(--color-primary)]" rel="noopener">Open staff console</a>
  </p>
</div>
<script>
  window.location.replace({{ console_url | json }});
</script>

{% schema %}
{
  "name": "Staff console redirect",
  "tag": "section",
  "class": "section-admin-redirect",
  "settings": []
}
{% endschema %}
