<div class="flex min-h-screen items-center justify-center px-4 py-12">
  <main class="w-full max-w-md text-center">
    {%- if settings.logo != blank -%}
      {{ settings.logo | image_url: width: 200 | image_tag: alt: shop.name, class: 'mx-auto mb-6 h-12 w-auto' }}
    {%- else -%}
      <h1 class="mb-6 font-heading text-2xl font-bold text-[var(--color-primary)]">{{ shop.name }}</h1>
    {%- endif -%}

    <h2 class="text-xl font-semibold text-[var(--color-trust)]">{{ 'general.password_page.login_form_heading' | t }}</h2>
    <p class="mt-2 text-sm text-[var(--color-muted)]">{{ 'general.password_page.login_form_password_label' | t }}</p>

    {% form 'storefront_password', class: 'mt-6' %}
      {{ form.errors | default_errors }}
      <input
        type="password"
        name="password"
        id="Password"
        placeholder="{{ 'general.password_page.login_form_password_placeholder' | t }}"
        class="mb-4 w-full rounded-lg border border-gray-200 p-3 text-sm"
      >
      <button type="submit" class="morbeez-btn-primary w-full border-0">
        {{ 'general.password_page.login_form_submit' | t }}
      </button>
    {% endform %}

    <p class="mt-6 text-sm text-[var(--color-muted)]">
      {{ 'general.password_page.admin_link_html' | t }}
    </p>
  </main>
</div>

{% schema %}
{
  "name": "t:sections.main_password.name",
  "settings": []
}
{% endschema %}
