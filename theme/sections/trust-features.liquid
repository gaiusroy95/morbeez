<section class="border-y border-[var(--color-border)] bg-white" id="MorbeezTrust-{{ section.id }}">
  <div class="morbeez-container py-6 md:py-8">
    <div class="grid grid-cols-2 gap-6 md:grid-cols-4 md:gap-8">
      {%- for block in section.blocks -%}
        <div class="flex flex-col items-center text-center sm:flex-row sm:items-start sm:text-left md:flex-col md:items-center md:text-center lg:flex-row lg:items-start lg:text-left" {{ block.shopify_attributes }}>
          <span class="mb-3 flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-[var(--color-primary)]/10 text-[var(--color-primary)] sm:mb-0 sm:mr-3 md:mb-3 md:mr-0 lg:mb-0 lg:mr-3">
            {%- case block.settings.icon -%}
              {%- when 'truck' -%}
                {%- render 'morbeez-icon', name: 'truck', class: 'h-6 w-6' -%}
              {%- when 'shield' -%}
                {%- render 'morbeez-icon', name: 'shield', class: 'h-6 w-6' -%}
              {%- when 'support' -%}
                {%- render 'morbeez-icon', name: 'phone', class: 'h-6 w-6' -%}
              {%- else -%}
                {%- render 'morbeez-icon', name: 'leaf', class: 'h-6 w-6' -%}
            {%- endcase -%}
          </span>
          <div>
            <p class="text-sm font-bold text-[var(--color-trust)]">{{ block.settings.title }}</p>
            <p class="mt-1 text-xs leading-relaxed text-[var(--color-muted)]">{{ block.settings.text }}</p>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "t:sections.trust_features.name",
  "tag": "section",
  "max_blocks": 4,
  "blocks": [
    {
      "type": "feature",
      "name": "t:sections.trust_features.blocks.feature.name",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "t:sections.trust_features.blocks.feature.settings.icon",
          "options": [
            { "value": "truck", "label": "Delivery" },
            { "value": "shield", "label": "Quality" },
            { "value": "support", "label": "Support" },
            { "value": "leaf", "label": "Organic" }
          ],
          "default": "leaf"
        },
        { "type": "text", "id": "title", "label": "t:sections.trust_features.blocks.feature.settings.title", "default": "Fast delivery" },
        { "type": "text", "id": "text", "label": "t:sections.trust_features.blocks.feature.settings.text", "default": "Pan-India shipping on agri inputs" }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.trust_features.presets.default",
      "blocks": [
        { "type": "feature", "settings": { "icon": "truck", "title": "Fast delivery", "text": "Reliable shipping across India" } },
        { "type": "feature", "settings": { "icon": "shield", "title": "Quality assured", "text": "Science-backed formulations" } },
        { "type": "feature", "settings": { "icon": "support", "title": "Expert support", "text": "Crop advisory on WhatsApp" } },
        { "type": "feature", "settings": { "icon": "leaf", "title": "Farmer-first", "text": "Trusted by growers nationwide" } }
      ]
    }
  ]
}
{% endschema %}
