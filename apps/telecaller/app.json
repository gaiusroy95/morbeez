{
  "expo": {
    "name": "Morbeez Telecaller",
    "slug": "morbeez-telecaller",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "morbeez-telecaller",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "icon": "./assets/app-icon.png",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "in.morbeez.telecaller"
    },
    "android": {
      "package": "in.morbeez.telecaller",
      "adaptiveIcon": {
        "foregroundImage": "./assets/app-icon.png",
        "backgroundColor": "#246d26"
      }
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "apiBaseUrl": "https://morbeez-api-5hbx.onrender.com",
      "eas": {
        "projectId": "ec66920f-2334-4e22-8650-cf5dd8021774"
      },
      "router": {}
    }
  }
}
