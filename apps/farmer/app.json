{
  "expo": {
    "name": "Morbeez Farmer",
    "slug": "morbeez-farmer",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "morbeez-farmer",
    "userInterfaceStyle": "light",
    "icon": "./assets/icon.png",
    "newArchEnabled": true,
    "ios": {
