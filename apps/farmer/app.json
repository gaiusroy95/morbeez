    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#1a4d32"
      },
      "package": "in.morbeez.farmer"
    },
    "plugins": ["expo-router"]
  }
}
