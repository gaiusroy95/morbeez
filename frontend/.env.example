# Morbeez staff console (Vite) — copy to .env.local for local dev

# Backend API origin (no trailing slash). Leave empty in dev to use Vite proxy.
# Production (Vercel): https://morbeez-api.onrender.com
VITE_API_BASE_URL=

# Vite dev proxy target when VITE_API_BASE_URL is empty
VITE_API_PROXY_TARGET=http://localhost:3000

# React Router basename (default /). Set only if hosting under a subpath.
