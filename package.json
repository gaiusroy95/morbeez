{
  "name": "morbeez-shopify",
  "version": "1.0.0-m1",
  "private": true,
  "description": "Morbeez agriculture commerce — Shopify theme & foundation",
  "scripts": {
    "dev:css": "tailwindcss -i ./theme/src/tailwind.css -o ./theme/assets/theme.css --watch",
    "build:css": "tailwindcss -i ./theme/src/tailwind.css -o ./theme/assets/theme.css --minify",
    "theme:dev": "shopify theme dev --path theme --theme 157069279431",
    "theme:push": "shopify theme push --path theme --theme 157069279431 --nodelete",
    "theme:push:live": "shopify theme push --path theme --theme 157075734727 --allow-live --nodelete",
    "theme:pull": "shopify theme pull --path theme --theme 157069279431",
    "theme:check": "shopify theme check --path theme",
    "catalog:generate": "node scripts/generate-product-catalog.mjs",
    "catalog:export-shopify": "node scripts/export-shopify-product-import.mjs",
    "build": "npm run build:css",
    "setup:m1": "node scripts/setup-m1.mjs",
    "setup:pages": "node scripts/setup-shopify-pages.mjs",
    "setup:menu": "node scripts/setup-shopify-menu.mjs",
    "verify:api": "node scripts/verify-render-api.mjs",
    "prepare:logos": "python scripts/prepare-logos.py",
    "admin:create-user": "node scripts/create-admin-user.mjs",
    "crm:seed": "node scripts/seed-telecaller-crm.mjs",
    "crm:masters": "node scripts/seed-crm-masters.mjs",
    "archive:reset-demo": "node scripts/reset-archive-for-production.mjs --mode=demo",
    "archive:reset": "node scripts/reset-archive-for-production.mjs --mode=full --confirm"
  },
  "devDependencies": {
    "@shopify/prettier-plugin-liquid": "^1.5.0",
    "prettier": "^3.3.0",
    "tailwindcss": "^3.4.0"
  }
}
