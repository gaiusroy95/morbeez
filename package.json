{
  "name": "morbeez-shopify",
  "version": "1.0.0-m1",
  "private": true,
  "description": "Morbeez agriculture commerce — Shopify theme & foundation",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:css": "tailwindcss -i ./theme/src/tailwind.css -o ./theme/assets/theme.css --watch",
    "build:css": "tailwindcss -i ./theme/src/tailwind.css -o ./theme/assets/theme.css --minify",
    "theme:dev": "shopify theme dev --path theme --environment development",
    "theme:push": "shopify theme push --path theme --environment development --nodelete",
    "theme:push:live": "shopify theme push --path theme --environment live --allow-live --nodelete",
    "theme:pull": "shopify theme pull --path theme --environment development",
    "theme:check": "shopify theme check --path theme",
    "catalog:generate": "node scripts/generate-product-catalog.mjs",
    "catalog:export-shopify": "node scripts/export-shopify-product-import.mjs",
    "build": "npm run build:css",
    "setup:m1": "node scripts/setup-m1.mjs",
    "setup:pages": "node scripts/setup-shopify-pages.mjs",
    "setup:menu": "node scripts/setup-shopify-menu.mjs",
    "dev:console": "npm run dev --prefix frontend",
    "build:console": "npm run build --prefix frontend",
    "dev:farmer": "npm run start --workspace @morbeez/app-farmer",
    "dev:warehouse": "npm run start --workspace @morbeez/app-warehouse",
    "dev:agronomist": "npm run start --workspace @morbeez/app-agronomist",
    "dev:telecaller": "npm run start --workspace @morbeez/app-telecaller",
    "dev:partner": "npm run start --workspace @morbeez/app-partner",
    "install:apps": "npm install --workspaces",
    "verify:api": "node scripts/verify-render-api.mjs",
    "prepare:logos": "python scripts/prepare-logos.py",
    "sync:app-icons": "node scripts/sync-app-icons.mjs",
    "eas-build-pre-install": "node scripts/sync-app-icons.mjs",
    "admin:create-user": "node scripts/create-admin-user.mjs",
    "crm:seed": "node scripts/seed-telecaller-crm.mjs",
    "crm:masters": "node scripts/seed-crm-masters.mjs",
    "archive:reset-demo": "node scripts/reset-archive-for-production.mjs --mode=demo",
    "archive:reset": "node scripts/reset-archive-for-production.mjs --mode=full --confirm"
  },
  "devDependencies": {
    "@shopify/prettier-plugin-liquid": "^1.5.0",
    "prettier": "^3.3.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.0"
  },
  "dependencies": {
    "react-native-svg": "15.15.4"
  },
  "overrides": {
    "react-native-svg": "15.15.4",
    "react-native-gifted-charts": {
      "react-native-svg": "15.15.4"
    },
    "gifted-charts-core": {
      "react-native-svg": "15.15.4"
    }
  }
}
